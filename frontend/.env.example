# No environment variables are required by default.
# The API base URL is set in src/config.js (apiBaseUrl).
#
# If you need to override the API URL at build time without editing config.js,
# add it here and read it in config.js via import.meta.env.VITE_API_BASE_URL.
#
# VITE_API_BASE_URL=http://localhost:8000
