# LLM
# LLM provider and model are env-only settings.
# Options for LLM_PROVIDER: openai | openrouter | gemini | ollama
LLM_PROVIDER=
LLM_MODEL=

OPENAI_API_KEY=

# OpenRouter is OpenAI-compatible.
# Use a model id from your OpenRouter account/catalog when using OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Daily Routine Assistant
OPENROUTER_SITE_URL=http://localhost

GEMINI_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434

# Data sources
# Weather uses Open-Meteo and does not need an API key.
# News uses DuckDuckGo and does not need an API key.
# Traffic uses TomTom Traffic API and requires this key.
TOMTOM_API_KEY=

# Set true only when your Python install trusts your network certificate chain.
# Corporate/self-signed proxy chains often require false for local development.
EXTERNAL_API_VERIFY_TLS=false

